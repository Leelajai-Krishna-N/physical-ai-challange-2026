<td><strong>{{$json.machine_id}}</strong></td>\n                </tr>\n                <tr>\n                    <td class=\"label\">Calculated Risk Score:</td>\n                    <td><strong>{{$json.risk_score}}/100</strong></td>\n                </tr>\n                <tr>\n                    <td class=\"label\">Classification:</td>\n                    <td>Localized Mechanical Failure</td>\n                </tr>\n                <tr>\n                    <td class=\"label\">Timestamp:</td>\n                    <td>{{$now}}</td>\n                </tr>\n            </table>\n\n            <h3>AI Investigator Reasoning:</h3>\n            <div class=\"reasoning-box\">\n                \"{{$json.reasoning_steps}}\"\n            </div>\n\n            <p><strong>Fleet Context:</strong> {{$json.fleet_context}}</p>\n\n            <a href=\"#\" class=\"button\">View Full Diagnostic Report</a>\n        </div>\n        <div class=\"footer\">\n            <p>Sent by <strong>Project Sentinel</strong>: Predictive Maintenance AI</p>\n            <p>BGS College of Engineering and Technology - AI & Data Science Dept.</p>\n        </div>\n    </div>\n</body>\n</html>",
